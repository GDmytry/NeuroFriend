# Address and port for the local Node bridge
CHAT_SERVER_HOST=0.0.0.0
CHAT_SERVER_PORT=3001

# Optional: add a bearer token so not everyone can use your endpoint
CHAT_SERVER_API_KEY=replace_me_with_a_long_random_string

# Local Ollama settings
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_KEEP_ALIVE=10m
OLLAMA_THINK=false
OLLAMA_NUM_PREDICT=220
OLLAMA_TEMPERATURE=0.2
